{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnalystAssessment",
  "type": "object",
  "properties": {
    "opportunities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "asset": { "type": "string" },
          "type": { "type": "string", "enum": ["long", "short", "hold"] },
          "rationale": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "required": ["asset", "type", "rationale", "confidence"]
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "severity": { "type": "number", "minimum": 0, "maximum": 10 }
        },
        "required": ["description", "severity"]
      }
    },
    "recommendation": { "type": "string", "enum": ["act", "wait", "exit"] },
    "topAsset": { "type": "string" },
    "confidenceScore": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "required": ["opportunities", "risks", "recommendation", "topAsset", "confidenceScore"]
}
